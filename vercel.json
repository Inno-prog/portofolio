{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/angular-build",
      "config": {
        "distFolder": "dist/portofolio/browser"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
